{
  "meta": {
    "title": "Pausalformen-Drill",
    "description": "Übung: Wie verändert sich die Aussprache eines Wortes wenn man am Wortende pausiert?",
    "sources": [
      {
        "name": "Wright's Grammar Vol I",
        "url": "https://archive.org/details/WrightsArabicGrammar1Of2"
      },
      {
        "name": "Quranic Arabic Corpus",
        "url": "https://corpus.quran.com/"
      }
    ]
  },
  "rules": [
    {
      "id": "tanwin_drop",
      "rule": "Tanwin fällt weg",
      "explanation": "Alle drei Tanwin-Formen (-un, -an, -in) werden in der Pause zu ihrem Kurzvokal ohne Nunation.",
      "examples": [
        {
          "context": "كِتَابٌ",
          "pausal": "كِتَابْ",
          "note": "Tanwin Damma (-un) → Sukun"
        },
        {
          "context": "كِتَابًا",
          "pausal": "كِتَابَا",
          "note": "Tanwin Fatha (-an) → langes -ā (die Alif bleibt!)"
        },
        {
          "context": "كِتَابٍ",
          "pausal": "كِتَابْ",
          "note": "Tanwin Kasra (-in) → Sukun"
        }
      ]
    },
    {
      "id": "case_drop",
      "rule": "Kasusendung fällt weg (bei definiten Nomen)",
      "explanation": "Bei definiten Nomen oder Verben fällt die Kasusendung in der Pause zu Sukun.",
      "examples": [
        {
          "context": "الْكِتَابُ",
          "pausal": "الْكِتَابْ",
          "note": "Nominativ Damma → Sukun"
        },
        {
          "context": "الْكِتَابِ",
          "pausal": "الْكِتَابْ",
          "note": "Genitiv Kasra → Sukun"
        },
        {
          "context": "الْكِتَابَ",
          "pausal": "الْكِتَابْ",
          "note": "Akkusativ Fatha → Sukun"
        }
      ]
    },
    {
      "id": "ta_marbuta",
      "rule": "Ta Marbuta wird zu Ha",
      "explanation": "ة wird in der Pause immer als ه (Ha) gesprochen — nie als Ta.",
      "examples": [
        {
          "context": "رَحْمَةً",
          "pausal": "رَحْمَهْ",
          "note": "Ta Marbuta + Tanwin → Ha + Sukun"
        },
        {
          "context": "الْجَنَّةِ",
          "pausal": "الْجَنَّهْ",
          "note": "Ta Marbuta + Kasra → Ha + Sukun"
        }
      ]
    },
    {
      "id": "tanwin_fatha_special",
      "rule": "Tanwin Fatha → langes -ā",
      "explanation": "Tanwin Fatha ist die EINZIGE Tanwin-Form die in der Pause zu einem hörbaren Vokal wird (langes ā), weil die orthographische Alif bleibt.",
      "examples": [
        {
          "context": "عَلِيمًا",
          "pausal": "عَلِيمَا",
          "note": "-an → -ā. Die Alif wird als langer Vokal gesprochen."
        },
        {
          "context": "رَحِيمًا",
          "pausal": "رَحِيمَا",
          "note": "Ebenso: Tanwin fällt, Alif bleibt als langer Vokal."
        }
      ]
    },
    {
      "id": "verb_mood_drop",
      "rule": "Verbmodus-Endung fällt weg",
      "explanation": "Bei Verben im Imperfekt fällt die Damma-Endung (Indikativ) in der Pause zu Sukun.",
      "examples": [
        {
          "context": "يَكْتُبُ",
          "pausal": "يَكْتُبْ",
          "note": "Indikativ Damma → Sukun"
        },
        {
          "context": "يَعْلَمُ",
          "pausal": "يَعْلَمْ",
          "note": "Ebenso: Damma → Sukun"
        }
      ]
    },
    {
      "id": "hamza_final_pause",
      "rule": "Finales Hamza bei Pause",
      "explanation": "Finales Hamza wird in der Pause wie im Kontext ausgesprochen, aber seine Vokalendung fällt weg. Wenn Hamza nach einem langen Vokal steht, bleibt der lange Vokal erhalten.",
      "examples": [
        {
          "context": "السَّمَاءُ",
          "pausal": "السَّمَاءْ",
          "note": "Hamza bleibt, nur Damma → Sukun"
        },
        {
          "context": "شَيْءٍ",
          "pausal": "شَيْءْ",
          "note": "Hamza bleibt, Kasra + Tanwin → Sukun"
        },
        {
          "context": "دُعَاءً",
          "pausal": "دُعَاءَا",
          "note": "Tanwin Fatha → langes Alif bleibt (wie bei normalem Tanwin Fatha)"
        },
        {
          "context": "الْمَاءَ",
          "pausal": "الْمَاءْ",
          "note": "Hamza nach langem Vokal, Fatha → Sukun"
        }
      ]
    },
    {
      "id": "long_vowel_pause",
      "rule": "Langvokale am Wortende bei Pause",
      "explanation": "Finale Langvokale (ا, و, ي als Vokalbuchstaben) bleiben in der Pause erhalten. Sie werden nicht verkürzt.",
      "examples": [
        {
          "context": "يَدْعُو",
          "pausal": "يَدْعُو",
          "note": "Finales Waw als Langvokal bleibt — kein Wegfall"
        },
        {
          "context": "يَهْدِي",
          "pausal": "يَهْدِي",
          "note": "Finales Ya als Langvokal bleibt"
        },
        {
          "context": "مُوسَىٰ",
          "pausal": "مُوسَى",
          "note": "Alif Maqsura bleibt — der finale a-Vokal wird beibehalten"
        },
        {
          "context": "عِيسَىٰ",
          "pausal": "عِيسَى",
          "note": "Ebenso bei Eigennamen auf Alif Maqsura"
        }
      ]
    },
    {
      "id": "tanwin_ta_marbuta",
      "rule": "Tanwin auf Ta Marbuta bei Pause",
      "explanation": "Bei Ta Marbuta mit Tanwin fallen SOWOHL der Tanwin ALS AUCH die Ta-Aussprache weg. Das Ergebnis ist Ha mit Sukun. Sonderfall Tanwin Fatha: Hier wird die Alif trotzdem NICHT gesprochen, weil Ta Marbuta sie blockiert.",
      "examples": [
        {
          "context": "رَحْمَةً",
          "pausal": "رَحْمَهْ",
          "note": "Ta Marbuta + Tanwin Fatha → Ha + Sukun (NICHT رَحْمَتَا!)"
        },
        {
          "context": "نِعْمَةٌ",
          "pausal": "نِعْمَهْ",
          "note": "Ta Marbuta + Tanwin Damma → Ha + Sukun"
        },
        {
          "context": "حَسَنَةٍ",
          "pausal": "حَسَنَهْ",
          "note": "Ta Marbuta + Tanwin Kasra → Ha + Sukun"
        }
      ]
    }
  ],
