    {
      "id": "alif_ya",
      "title": "Alif als Ya (Alif Maqsura) geschrieben",
      "description": "In einigen Wörtern wird das finale Alif als Ya ohne Punkte (Alif Maqsura ى) geschrieben, wo die moderne Orthographie ein reguläres Alif (ا) verwenden würde, oder umgekehrt.",
      "examples": [
        {
          "quranOrtho": "لدى",
          "modernOrtho": "لدى",
          "transliteration": "ladā",
          "meaning": "bei",
          "note": "Übereinstimmung — Alif Maqsura in beiden",
          "verifyUrl": "https://corpus.quran.com/wordbyword.jsp?chapter=6&verse=61"
        },
        {
          "quranOrtho": "يتوفىكم",
          "modernOrtho": "يتوفاكم",
          "transliteration": "yatawaffākum",
          "meaning": "Er beruft euch zurück",
          "locations": [
            "6:61"
          ],
          "note": "Ya-Schreibung statt Alif",
          "verifyUrl": "https://corpus.quran.com/wordbyword.jsp?chapter=6&verse=61"
        },
        {
          "quranOrtho": "تترا",
          "modernOrtho": "تترى",
          "transliteration": "tatrā",
          "meaning": "nacheinander",
          "locations": [
            "23:44"
          ],
          "note": "Alif statt Alif Maqsura",
          "verifyUrl": "https://corpus.quran.com/wordbyword.jsp?chapter=23&verse=44"
        }
      ]
    },
