      "id": "triptote_indefinite",
      "title": "Triptota (dreiflektierende Nomen) — indefinit",
      "description": "Reguläre Nomen mit drei Kasusendungen und Nunation (Tanwin). Dies ist das Standardmuster der arabischen Nominalflexion.",
      "table": {
        "nominative": {
          "ending": "-un (ٌ)",
          "example": "كِتَابٌ",
          "function": "Subjekt (Mubtada/Fa3il), Prädikat (Xabar)"
        },
        "accusative": {
          "ending": "-an (ً)",
          "example": "كِتَابًا",
          "function": "Objekt (Maf3ul bihi), Adverbial (Hal, Ẓarf), nach inna und Schwestern"
        },
        "genitive": {
          "ending": "-in (ٍ)",
          "example": "كِتَابٍ",
          "function": "Nach Präposition (Harfi Jarr), Iḍāfa-Zweitglied (Mudaf ilayhi)"
        }
      },
