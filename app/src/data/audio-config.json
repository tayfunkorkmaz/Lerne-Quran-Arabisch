{
  "meta": {
    "description": "Audio-Konfiguration für Quran-Vers-Audio mit everyayah.com und weiteren Quellen",
    "urlPattern": "https://everyayah.com/data/{reciterFolder}/{surahPadded}{ayahPadded}.mp3",
    "paddingRules": {
      "surah": "3 Stellen, mit führenden Nullen (001-114)",
      "ayah": "3 Stellen, mit führenden Nullen (001-286)"
    },
    "example": "https://everyayah.com/data/Husary_128kbps/002005.mp3 = Sure 2, Vers 5, Aussprache A"
  },
  "urlConstruction": {
    "template": "https://everyayah.com/data/{reciterFolder}/{surahPadded}{ayahPadded}.mp3",
    "javascript": "function getAudioUrl(reciterFolder, surah, ayah) {\n  const surahStr = String(surah).padStart(3, '0');\n  const ayahStr = String(ayah).padStart(3, '0');\n  return `https://everyayah.com/data/${reciterFolder}/${surahStr}${ayahStr}.mp3`;\n}",
    "basmalaNote": "Die Basmala steht in den historischen Rasm-Handschriften vor Vers 1 jeder Sure (außer Sure 9). In der konventionellen Kufi-Verszählung ist sie Vers 1:1 in Sure 1, aber separat in den anderen Suren.",
    "surahRange": {
      "min": 1,
      "max": 114
    },
    "specialCases": {
      "surah1_ayahCount": 7,
      "surah9_noBasmala": true,
      "surah114_ayahCount": 6
    }
  },
  "reciters": [
    {
      "id": "husary_standard",
      "name": "Aussprache A (klar, langsam)",
      "style": "Langsam, klar",
      "germanDescription": "Langsame, klare Audioaufnahme",
      "folder": "Husary_128kbps",
      "bitrate": "128kbps",
      "format": "mp3",
      "recommended": true,
      "exampleUrl": "https://everyayah.com/data/Husary_128kbps/001001.mp3",
      "notes": "Langsame, präzise Aufnahme."
    },
    {
      "id": "husary_wiederholung",
      "name": "Aussprache A+ (langsam, mit Wiederholungen)",
      "style": "Langsam mit Wiederholungen",
      "germanDescription": "Aufnahme mit Verswiederholungen — nützlich zum Einprägen der Aussprache.",
      "folder": "Husary_Muallim_128kbps",
      "bitrate": "128kbps",
      "format": "mp3",
      "recommended": false,
      "exampleUrl": "https://everyayah.com/data/Husary_Muallim_128kbps/001001.mp3",
      "notes": "Version mit Wiederholungen jedes Verses."
    },
    {
      "id": "minshawi_standard",
      "name": "Aussprache B (moderates Tempo)",
