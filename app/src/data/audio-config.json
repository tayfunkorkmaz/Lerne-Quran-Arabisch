        "name": "mp3quran.net",
        "urlTemplate": "https://server{N}.mp3quran.net/{reciterId}/{surahPadded}.mp3",
        "notes": "Bietet ganze Suren als einzelne Dateien an, nicht einzelne Verse. Weniger geeignet für Vers-genaus Abspielen."
      }
    ]
  },
  "fallbackConfig": {
    "description": "Konfiguration des Audio-Fallback-Systems (audio.js)",
    "strategy": [
      "1. IndexedDB-Cache (via localforage) — bereits geladene Audio-URLs",
      "2. everyayah.com — primäre externe Quelle",
      "3. Web Speech API (SpeechSynthesis) — Sprachsynthese für arabischen Text",
      "4. Highlight-only — nur visuelle Wortverfolgung, kein Audio"
    ],
    "networkTimeoutMs": 5000,
