      "folder": "Minshawi_Murattal_128kbps",
      "bitrate": "128kbps",
      "format": "mp3",
      "recommended": true,
      "exampleUrl": "https://everyayah.com/data/Minshawi_Murattal_128kbps/001001.mp3",
      "notes": "Klare Aufnahme in moderatem Tempo."
    },
    {
      "id": "minshawi_melodisch",
      "name": "Aussprache B+ (melodisch, langsam)",
      "style": "Melodisch, langsam",
      "germanDescription": "Melodische Aufnahme in langsamem Tempo — gut für Prosodie-Analyse",
      "folder": "Minshawi_Mujawwad_128kbps",
      "bitrate": "128kbps",
      "format": "mp3",
      "recommended": false,
      "exampleUrl": "https://everyayah.com/data/Minshawi_Mujawwad_128kbps/001001.mp3",
      "notes": "Melodische Aufnahme in langsamem Tempo."
    },
    {
      "id": "abdulbaset_standard",
      "name": "Aussprache C (moderates Tempo)",
      "style": "Moderates Tempo",
      "germanDescription": "Klare Audioaufnahme in moderatem Tempo",
      "folder": "Abdul_Basit_Murattal_192kbps",
      "bitrate": "192kbps",
      "format": "mp3",
      "recommended": false,
      "exampleUrl": "https://everyayah.com/data/Abdul_Basit_Murattal_192kbps/001001.mp3",
      "notes": "Klare Aufnahme in moderatem Tempo, 192kbps."
    }
  ],
  "defaultReciter": "husary_standard",
  "playbackSettings": {
    "defaultSpeed": 1,
    "availableSpeeds": [
      0.5,
      0.75,
      1,
      1.25,
      1.5
    ],
    "repeatOptions": {
      "none": "Einmal abspielen",
      "verse": "Vers wiederholen",
      "range": "Versbereich wiederholen",
      "surah": "Ganze Sure wiederholen"
    },
    "delayBetweenVerses": {
      "default": 0,
      "learning": 2000,
      "memorization": 3000
    }
  },
  "alternativeSources": {
    "description": "Alternative Audioquellen, falls everyayah.com nicht verfügbar ist",
    "sources": [
      {
        "name": "QuranicAudio.com",
        "urlTemplate": "https://download.quranicaudio.com/quran/{reciterSlug}/{surahPadded}{ayahPadded}.mp3",
        "notes": "Alternative Audioquelle; URL-Schema muss bei Nutzung getestet werden",
        "reciters": {
          "husary": "mahmoud_khaleel_al-husaree",
          "minshawi": "muhammad_siddeeq_al-minshaawee"
        }
      },
