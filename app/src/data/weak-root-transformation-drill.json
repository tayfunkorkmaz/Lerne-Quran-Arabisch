  "transformations": [
    {
      "id": "hollow_waw",
      "title": "Hohle Wurzeln mit Waw (فَعَلَ wo ع = و)",
      "root": "ق-و-ل",
      "meaning": "sagen",
      "forms": [
        {
          "form": "Perfekt 3ms",
          "expected": "قَالَ",
          "note": "Waw → langes Alif (Fatha + و → ā)"
        },
        {
          "form": "Perfekt 3fs",
          "expected": "قَالَتْ",
          "note": "Waw → Alif, Ta Marbuta Suffix"
        },
        {
          "form": "Perfekt 3mp",
          "expected": "قَالُوا",
          "note": "Waw → Alif, Waw al-Jamaʿa + Schutz-Alif"
        },
        {
          "form": "Imperfekt 3ms",
          "expected": "يَقُولُ",
          "note": "Waw bleibt als langer Vokal ū"
        },
        {
          "form": "Imperativ 2ms",
          "expected": "قُلْ",
          "note": "Waw komplett weggefallen! Nur 2 sichtbare Buchstaben"
        },
        {
          "form": "Passiv Perfekt",
          "expected": "قِيلَ",
          "note": "Waw → Ya (Passiv-Transformation: u-i → ī)"
        },
        {
          "form": "Aktiv-Partizip",
          "expected": "قَائِل",
          "note": "Waw → Hamza auf Ya-Sitz (قَاوِل → قَائِل)"
        },
        {
          "form": "Masdar",
          "expected": "قَوْل",
          "note": "Waw bleibt als Konsonant im Masdar"
        }
      ],
      "quranExamples": [
        {
          "ref": "112:1",
          "arabic": "قُلْ هُوَ ٱللَّهُ أَحَدٌ",
          "form": "Imperativ",
          "verifyUrl": "https://corpus.quran.com/wordbyword.jsp?chapter=112&verse=1"
        },
        {
          "ref": "2:30",
          "arabic": "وَإِذْ قَالَ رَبُّكَ لِلْمَلَٰٓئِكَةِ",
          "form": "Perfekt 3ms",
          "verifyUrl": "https://corpus.quran.com/wordbyword.jsp?chapter=2&verse=30"
        },
        {
          "ref": "2:8",
          "arabic": "يَقُولُ ءَامَنَّا بِٱللَّهِ",
          "form": "Imperfekt 3ms",
          "verifyUrl": "https://corpus.quran.com/wordbyword.jsp?chapter=2&verse=8"
        }
      ],
      "verifyUrl": "https://archive.org/details/WrightsArabicGrammar1Of2/page/n130"
    },
